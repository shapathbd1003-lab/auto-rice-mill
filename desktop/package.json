{
  "name": "rice-mill-desktop",
  "version": "1.0.0",
  "description": "Auto Rice Mill Desktop Application",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"vite --config vite.config.js\" \"wait-on http://localhost:5174 && cross-env NODE_ENV=development electron .\"",
    "build": "vite build --config vite.config.js && electron-builder",
    "dist": "vite build --config vite.config.js && electron-builder --win"
  },
  "dependencies": {
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^5.14.19",
    "@mui/material": "^5.14.20",
    "@mui/x-date-pickers": "^6.18.2",
    "@reduxjs/toolkit": "^2.0.1",
    "axios": "^1.6.2",
    "better-sqlite3": "^9.2.2",
    "dayjs": "^1.11.10",
    "electron-log": "^5.0.1",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.7",
    "i18next": "^23.7.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^13.5.0",
    "react-redux": "^9.0.4",
    "react-router-dom": "^6.20.1",
    "recharts": "^2.10.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "vite": "^5.0.7",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.ricemillbd.app",
    "productName": "Auto Rice Mill",
    "asar": true,
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    },
    "files": [
      "dist/index.html",
      "dist/assets/**/*",
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "electron/database/schema.sql",
        "to": "database/schema.sql"
      }
    ]
  }
}
